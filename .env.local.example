# Supabase project configuration
# -- safe to share (exposed to the browser) --
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# -- SECRET: never commit or share --
# Used only by server-side code and the one-off import script.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Power Automate HTTP trigger URL — appends new teaching case rows to the
# Teaching_Case_Repository.xlsx table in OneDrive. Leave blank to skip
# OneDrive sync (site-side Supabase mirror still records the case).
POWER_AUTOMATE_WEBHOOK_URL=

# -- SECRET: never commit or share --
# Shared site password. Users sign in with their allowlisted institutional
# email plus this password.
SITE_PASSWORD=

# -- shown in rendered HTML to authenticated users --
# Persistent Webex meeting URL used as the default join link for Breakfast
# Club and Fracture Conference sessions. Leave blank to hide the join link
# (admins can still set a per-session URL in the UI).
NEXT_PUBLIC_WEBEX_URL=

# -- shown in rendered HTML to authenticated users --
# Direct link to the OneDrive workbook holding the teaching-case repository
# (the PHI-containing spreadsheet). Leave blank to hide the "Open workbook"
# button on the Teaching Case Repository card.
NEXT_PUBLIC_TEACHING_CASE_REPO_URL=